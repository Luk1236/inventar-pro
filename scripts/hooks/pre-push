#!/bin/sh
# Pre-push hook: pytest + frontend tsc-delta check.
#
# Backend pytest: skipped silently if no MongoDB on localhost:27017.
# Frontend tsc:   delta-check against frontend/.tsc-baseline. Push is blocked
#                 only if the error count INCREASED — pre-existing errors
#                 are tracked but not blocking. Skipped silently if no
#                 frontend/node_modules/typescript.
#
# Install: cp scripts/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ─── Backend pytest ─────────────────────────────────────────────────────
if python -c "import socket; s=socket.socket(); s.settimeout(0.5); s.connect(('localhost',27017))" 2>/dev/null; then
    echo "pre-push: running backend pytest..."
    cd "$REPO_ROOT/backend"
    if ! python -m pytest tests/ -q --tb=short; then
        echo ""
        echo "pre-push: pytest failed — push aborted."
        echo "  override (NOT recommended): git push --no-verify"
        exit 1
    fi
    echo "pre-push: pytest green."
else
    echo "pre-push: no MongoDB on localhost:27017 — skipping pytest."
fi

# ─── Frontend TypeScript delta-check ────────────────────────────────────
# Catches new undefined-references / missing-import bugs without forcing a
# full pre-existing-error cleanup first. Blocks push only when the error
# count goes up.
if [ -f "$REPO_ROOT/frontend/node_modules/typescript/bin/tsc" ]; then
    echo "pre-push: running frontend tsc --noEmit (delta check)..."
    cd "$REPO_ROOT/frontend"
    CURRENT=$(npx tsc --noEmit 2>&1 | grep -cE 'error TS' || true)
    BASELINE=0
    if [ -f .tsc-baseline ]; then
        BASELINE=$(cat .tsc-baseline)
    fi
    echo "pre-push: tsc errors — current: $CURRENT, baseline: $BASELINE"
    if [ "$CURRENT" -gt "$BASELINE" ]; then
        DELTA=$((CURRENT - BASELINE))
        echo ""
        echo "pre-push: tsc found $DELTA NEW type errors — push aborted."
        echo "  see them: cd frontend && npx tsc --noEmit | head -40"
        echo "  if intentional, update baseline: echo $CURRENT > frontend/.tsc-baseline"
        echo "  override (NOT recommended): git push --no-verify"
        exit 1
    fi
    if [ "$CURRENT" -lt "$BASELINE" ]; then
        echo "pre-push: tsc errors went DOWN ($BASELINE -> $CURRENT). Update the baseline:"
        echo "  echo $CURRENT > frontend/.tsc-baseline && git add frontend/.tsc-baseline"
    fi
    echo "pre-push: tsc delta green."
else
    echo "pre-push: no frontend/node_modules/typescript — skipping tsc."
fi

echo "pre-push: all checks passed — proceeding with push."
